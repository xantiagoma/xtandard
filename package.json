{
  "name": "xantiagoma",
  "version": "0.0.1",
  "description": "Santiago Montoya's utilities and tools",
  "keywords": [
    "utilities",
    "xantiagoma"
  ],
  "homepage": "https://github.com/xantiagoma/xantiagoma-lib#readme",
  "bugs": {
    "url": "https://github.com/xantiagoma/xantiagoma-lib/issues"
  },
  "license": "MIT",
  "author": "Santiago Montoya <xantiagoma@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/xantiagoma/xantiagoma-lib.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run",
    "lint": "vp lint",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp lint && vp fmt --check && tsc --noEmit",
    "release": "changelogen --release --push"
  },
  "devDependencies": {
    "changelogen": "^0.6.2",
    "vite-plus": "^0.1.22"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
